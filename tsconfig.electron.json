{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist-electron",
    "rootDir": ".",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "electron/**/*.ts",
    "src/core/constants.ts",
    "src/core/date.ts",
    "src/core/parseWorkbook.ts",
    "src/types/pilot.ts"
  ]
}
