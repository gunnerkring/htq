{
  "name": "hours-to-qualify-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Hours to Qualify desktop app",
  "author": "Gunner Kring",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node electron/dev-runner.cjs",
    "dev:web": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:all": "npm run build && electron-builder --win nsis portable",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:mac:dir": "npm run build && electron-builder --mac dir",
    "dist:mac:universal": "npm run build && electron-builder --mac dmg zip --universal"
  },
  "build": {
    "appId": "com.htq.desktop",
    "productName": "Hours to Qualify",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "${productName} Portable ${version}.${ext}"
    }
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.0",
    "vite": "^6.4.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0"
  }
}
